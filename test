import csv
import os
import sys
from datetime import datetime

ATT_FILE = os.path.join(os.path.dirname(__file__), "attendance.csv")


def ensure_file():
    if not os.path.exists(ATT_FILE):
        with open(ATT_FILE, "w", newline="", encoding="utf-8") as f:
            writer = csv.writer(f)
            writer.writerow(["timestamp", "name", "action"])


def record(name, action):
    ts = datetime.now().isoformat(sep=" ", timespec="seconds")
    with open(ATT_FILE, "a", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow([ts, name, action])
    print(f"{ts} - {name} -> {action}")


def list_today():
    today = datetime.now().date().isoformat()
    with open(ATT_FILE, newline="", encoding="utf-8") as f:
        reader = csv.reader(f)
        next(reader, None)
        for row in reader:
            if row and row[0].startswith(today):
                print(", ".join(row))


def help_and_exit():
    print("使い方:")
    print("  python test checkin <name>   # 出勤登録")
    print("  python test checkout <name>  # 退勤登録")
    print("  python test list             # 本日の記録を表示")
    sys.exit(0)


def main(argv):
    if len(argv) < 2:
        help_and_exit()
    cmd = argv[1].lower()
    ensure_file()
    if cmd == "checkin" and len(argv) >= 3:
        record(argv[2], "checkin")
    elif cmd == "checkout" and len(argv) >= 3:
        record(argv[2], "checkout")
    elif cmd == "list":
        list_today()
    else:
        help_and_exit()


if __name__ == "__main__":
    main(sys.argv)
